rules_version = '2';
// AJK PSC — Firestore security rules
// All reads and writes are done server-side by the service account (Admin SDK / REST API),
// so the database itself is locked down completely.
// Client-side SDK access is intentionally disabled.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
